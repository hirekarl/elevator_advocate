# Development Settings
# Set to True to use Mock Geoclient while waiting for NYC API activation
USE_MOCK_GEOCLIENT=False
# Set to True to use Mock SerpAPI while saving API credits
USE_MOCK_SERPAPI=True

# NYC Geoclient API v2 (Address-to-BIN Mapping)
# Register at: https://api-portal.nyc.gov/
# Subscribe to "Geoclient v2" and use your "Primary Key"
NYC_API_KEY=your_geoclient_api_key_here

# NYC SODA API (Elevator Complaints Dataset kqwi-7ncn)
# Obtain App Token at: https://data.cityofnewyork.us/profile/edit/developer_settings
SODA_APP_TOKEN=your_soda_app_token_here

# AI & Media Intelligence (News Search & Extraction)
# Get Gemini Key: https://aistudio.google.com/app/apikey
# Get SerpAPI Key: https://serpapi.com/dashboard
GEMINI_API_KEY=your_gemini_api_key_here
SERPAPI_KEY=your_serpapi_api_key_here

# Django Settings
# Generate a secure key (e.g., using 'openssl rand -base64 32')
DJANGO_SECRET_KEY=generate_a_secure_random_key_here
DJANGO_DEBUG=True
DJANGO_TIME_ZONE=America/New_York

# Production Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://elevator-advocate-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://elevator-advocate-frontend.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,elevator-advocate-api.onrender.com

# Seed credentials — used by 'manage.py seed_users' on Render deployment
# Set SEED_ADMIN_PASSWORD and SEED_USER_PASSWORD in the Render dashboard (never commit real values)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@elevatoradvocate.nyc
SEED_ADMIN_PASSWORD=your_secure_admin_password_here
SEED_USER_PASSWORD=your_secure_user_password_here