# NYC Geoclient API v2
# Obtain at: https://developer.cityofnewyork.us/
NYC_API_KEY=your_geoclient_api_key_here

# NYC SODA API (Elevator Complaints)
# Obtain at: https://data.cityofnewyork.us/login
SODA_APP_TOKEN=your_soda_app_token_here

# Django Settings
DJANGO_SECRET_KEY=generate_a_secure_random_key_here
DJANGO_DEBUG=True
DJANGO_TIME_ZONE=America/New_York
